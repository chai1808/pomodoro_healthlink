# Google Health API
# ローカル: VITE_* を設定。Vercel では GOOGLE_* でも可（/api/config 経由で読み込み）
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_REDIRECT_URI=https://pomodoro-healthlink.vercel.app/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_REDIRECT_URI=https://pomodoro-healthlink.vercel.app/auth/google/callback
GOOGLE_CLIENT_SECRET=

# Web Push（node scripts/generate-vapid.mjs で生成）
VITE_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@pomodoro-healthlink.vercel.app

# 本番: Upstash Redis（スケジュール保存）。未設定時は dev のみ in-memory フォールバック
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Vercel Cron 保護（任意）
CRON_SECRET=
