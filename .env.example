# Fitbit OAuth (PKCE)
VITE_FITBIT_CLIENT_ID=
VITE_FITBIT_REDIRECT_URI=http://localhost:5173/

# OpenWeatherMap（.env.example はテンプレート。実際のキーは .env に設定）
VITE_OPENWEATHER_API_KEY=
VITE_WEATHER_LAT=
VITE_WEATHER_LON=

# 気象庁 警報・注意報（任意。未設定時は緯度経度から推定）
# 三重県の例: VITE_JMA_OFFICE_CODE=240000 / VITE_JMA_AREA_CODE=2421100
VITE_JMA_OFFICE_CODE=
VITE_JMA_AREA_CODE=

# false にすると API キー未設定時もモックを使わない
VITE_USE_MOCK=true
