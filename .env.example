# Google Health API（Fitbit データ）— 任意。未設定時はデモデータを表示
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_REDIRECT_URI=https://pomodoro-healthlink.vercel.app/auth/google/callback

# ローカル開発時の例
# VITE_GOOGLE_REDIRECT_URI=http://localhost:5173/auth/google/callback

# サーバー側のみ（VITE_ プレフィックスなし・.env にのみ設定・Git にコミットしない）
# GOOGLE_CLIENT_SECRET=
