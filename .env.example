# Fitbit OAuth (PKCE) — 任意。未設定時はデモデータを表示
VITE_FITBIT_CLIENT_ID=
# VITE_FITBIT_REDIRECT_URI=http://localhost:5173/

# 位置のフォールバック（任意）
# 未設定時: ブラウザの位置情報 → 名古屋（35.1814, 136.9063）
# 公開デモ用の例（名古屋市）:
VITE_WEATHER_LAT=35.1814
VITE_WEATHER_LON=136.9063

# 気象庁（任意。未設定時は緯度経度から自動推定）
# VITE_JMA_OFFICE_CODE=230000
# VITE_JMA_AREA_CODE=2310000
